# ══════════════════════════════════════════════════════════════
#  template.env — Plantilla de variables de entorno
#  Copia este archivo como backend/.env y rellena los valores.
#  Este archivo SÍ se sube al repositorio (sin valores reales).
# ══════════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────────
# Cadena de conexión completa a la base de datos PostgreSQL.
# Formato: postgresql://usuario:password@host:puerto/nombre_db
# Railway la provee automáticamente al agregar el servicio de Postgres.
DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db

# ── Cloudinary (almacenamiento de comprobantes) ────────────────
# Obten estas credenciales en: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── Servidor ───────────────────────────────────────────────────
# Puerto del servidor backend. Railway lo sobreescribe automáticamente.
PORT=3001
